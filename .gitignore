# =============================================================================
# .gitignore — Proyecto DCA_ANOVA
# =============================================================================

# ---------------------------------------------------------------------------
# ENTORNO VIRTUAL — nunca subir al repo (es local y pesa mucho)
# ---------------------------------------------------------------------------
venv/
.venv/
env/
.env/

# ---------------------------------------------------------------------------
# PYTHON — archivos compilados y caché (se generan automáticamente)
# ---------------------------------------------------------------------------
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ---------------------------------------------------------------------------
# OUTPUTS GENERADOS — opcional: decide si quieres subir los gráficos o no
# Si tu equipo necesita ver los gráficos sin ejecutar el código, comenta estas líneas
# ---------------------------------------------------------------------------
report/

# ---------------------------------------------------------------------------
# VS CODE — configuración local (cada quien tiene la suya)
# ---------------------------------------------------------------------------
.vscode/
*.code-workspace

# ---------------------------------------------------------------------------
# SISTEMA OPERATIVO
# ---------------------------------------------------------------------------
.DS_Store          # Mac
Thumbs.db          # Windows
desktop.ini        # Windows

# ---------------------------------------------------------------------------
# JUPYTER (si usan notebooks)
# ---------------------------------------------------------------------------
.ipynb_checkpoints/
*.ipynb

# ---------------------------------------------------------------------------
# VARIABLES DE ENTORNO (credenciales, claves — NUNCA al repo)
# ---------------------------------------------------------------------------
.env
*.env